"use client";

import Link from "next/link";
import { usePathname } from "next/navigation";
import { useEffect, useState } from "react";
import { supabase } from "../../lib/supabase";
import {
  Home,
  Search,
  Plus,
  MessageCircle,
  User,
} from "lucide-react";

export default function BottomNav() {
  const pathname = usePathname();

const [userId, setUserId] =
  useState<string | null>(null);

useEffect(() => {
  async function loadUser() {
    const {
      data: { session },
    } = await supabase.auth.getSession();

    setUserId(
      session?.user?.id ?? null
    );
  }

  loadUser();
}, []);

  const navItems = [
    {
      href: "/",
      icon: Home,
    },
    {
      href: "/search",
      icon: Search,
    },
    {
      href: "/post",
      icon: Plus,
      center: true,
    },
    {
      href: "/messages",
      icon: MessageCircle,
    },
{
  href: userId
    ? `/profile/${userId}`
    : "/signin",
  icon: User,
},
  ];

  return (
    <nav className="fixed bottom-0 left-0 right-0 z-50 bg-[#050505] border-t border-white/10">
      <div className="max-w-md mx-auto flex items-center justify-around h-16 px-6">

        {navItems.map((item) => {
          const Icon = item.icon;
          const active =
            pathname === item.href;

          // Center Post Button
          if (item.center) {
            return (
              <Link
                key={item.href}
                href={item.href}
                className="
                  w-12 h-12
                  rounded-full
                  bg-gradient-to-br
                  from-violet-500
                  to-emerald-400
                  flex
                  items-center
                  justify-center
                  shadow-lg
                  active:scale-95
                  transition
                "
              >
                <Icon
                  size={26}
                  className="text-black"
                  strokeWidth={2.5}
                />
              </Link>
            );
          }

          return (
            <Link
              key={item.href}
              href={item.href}
              className={`
                transition
                ${
                  active
                    ? "text-white"
                    : "text-white/40"
                }
              `}
            >
              <Icon
                size={25}
                strokeWidth={2.2}
              />
            </Link>
          );
        })}
      </div>
    </nav>
  );
}
